# Retail AI Platform - Environment Variables
# Copy this to .env and fill in values

# ═════════════════════════════════════════════════
#  Gemini API (Optional - activates Mode B LLM)
# ═════════════════════════════════════════════════
# Get your free key at: https://aistudio.google.com/apikey
# Without this, the platform uses the built-in NLG engine (Mode A)
GEMINI_API_KEY=

# ═════════════════════════════════════════════════
#  API Server
# ═════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8000